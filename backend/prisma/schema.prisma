generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  password     String
  name         String
  categories   Category[]
  ingredients  Ingredient[]
  recipes      Recipe[]
  menus        Menu[]
  restaurants  Restaurant[]
  suppliers              Supplier[]
  storageLocations       StorageLocation[]
  ingredientCategories   IngredientCategory[]
  ingredientTags         IngredientTag[]
  receipts               Receipt[]
  subAccounts            SubAccount[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

// ─── Recipe Management ───

model Category {
  id            String        @id @default(cuid())
  name          String
  description   String?
  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subcategories Subcategory[]
  recipes       Recipe[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@unique([name, userId])
}

model Subcategory {
  id          String   @id @default(cuid())
  name        String
  description String?
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  recipes     Recipe[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([name, categoryId])
}

model Supplier {
  id           String   @id @default(cuid())
  name         String
  phone        String?
  email        String?
  deliveryType String?  // e.g. "Truck", "Pickup", "Courier", "Walk-in"
  notes        String?
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([name, userId])
}

model StorageLocation {
  id        String   @id @default(cuid())
  name      String
  notes     String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, userId])
}

model IngredientCategory {
  id             String                  @id @default(cuid())
  name           String
  userId         String
  user           User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  subcategories  IngredientSubcategory[]
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  @@unique([name, userId])
}

model IngredientSubcategory {
  id         String             @id @default(cuid())
  name       String
  categoryId String
  category   IngredientCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  @@unique([name, categoryId])
}

model IngredientTag {
  id          String       @id @default(cuid())
  name        String
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  ingredients Ingredient[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([name, userId])
}

model Ingredient {
  id               String             @id @default(cuid())
  name             String
  unit             String?
  category         String?
  subcategory      String?
  supplier         String?            // supplier name (from Settings)
  purchaseUnit     String?            // how it's bought: kg, box, case, etc.
  purchaseQty      Float?             // qty per purchase unit (e.g. 10kg per box)
  unitPrice        Float?             // price per purchase unit
  currency         String?            @default("USD")
  minStock         Float?             // minimum stock level
  notes            String?
  userId           String
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  tags             IngredientTag[]
  recipeIngredients RecipeIngredient[]
  orderItems       OrderItem[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@unique([name, userId])
}

model Recipe {
  id              String             @id @default(cuid())
  title           String
  description     String?
  instructions    String?
  prepTime        Int?
  cookTime        Int?
  servings        Int?
  difficulty      Difficulty         @default(MEDIUM)
  imageUrl        String?
  userId          String
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId      String?
  category        Category?          @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  subcategoryId   String?
  subcategory     Subcategory?       @relation(fields: [subcategoryId], references: [id], onDelete: SetNull)
  ingredients     RecipeIngredient[]
  menuItems       MenuItem[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}

model RecipeIngredient {
  id           String     @id @default(cuid())
  quantity     Float
  unit         String?
  notes        String?
  recipeId     String
  recipe       Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@unique([recipeId, ingredientId])
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

// ─── Menu Management ───

model Menu {
  id          String     @id @default(cuid())
  name        String
  description String?
  isActive    Boolean    @default(true)
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       MenuItem[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model MenuItem {
  id       String  @id @default(cuid())
  price    Float?
  notes    String?
  section  String?
  sortOrder Int    @default(0)
  menuId   String
  menu     Menu    @relation(fields: [menuId], references: [id], onDelete: Cascade)
  recipeId String
  recipe   Recipe  @relation(fields: [recipeId], references: [id], onDelete: Cascade)
}

// ─── Employee Scheduling ───

model Restaurant {
  id         String     @id @default(cuid())
  name       String
  address    String?
  phone      String?
  logoUrl    String?
  details    String?
  shareToken String     @unique @default(cuid())
  userId     String
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  employees  Employee[]
  schedules  Schedule[]
  orders     Order[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model Employee {
  id             String                  @id @default(cuid())
  name           String
  role           String?
  phone          String?
  email          String?
  color          String?
  isActive       Boolean                 @default(true)
  hourlyRate     Float?
  restaurantId   String
  restaurant     Restaurant              @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  shifts         Shift[]
  scheduleOrders ScheduleEmployeeOrder[]
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
}

model Schedule {
  id           String     @id @default(cuid())
  weekStart    DateTime
  weekEnd      DateTime
  notes        String?
  published    Boolean    @default(false)
  restaurantId String
  restaurant     Restaurant              @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  shifts         Shift[]
  employeeOrders ScheduleEmployeeOrder[]
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  @@unique([weekStart, restaurantId])
}

model Shift {
  id            String     @id @default(cuid())
  dayOfWeek     Int
  startTime     String
  endTime       String
  shiftType     ShiftType  @default(WORK)
  breakMinutes  Int        @default(0)
  notes         String?
  employeeId    String
  employee      Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  scheduleId    String
  schedule      Schedule   @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model ScheduleEmployeeOrder {
  id           String   @id @default(cuid())
  scheduleId   String
  schedule     Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  employeeId   String
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  displayOrder Int      @default(0)

  @@unique([scheduleId, employeeId])
}

enum ShiftType {
  WORK
  BREAK
  DAY_OFF
  SICK
  VACATION
}

// ─── Ingredient Orders ───

model Order {
  id             String       @id @default(cuid())
  restaurantId   String
  restaurant     Restaurant   @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  status         OrderStatus  @default(ORDERED)
  deliveryType   String?      // e.g. "Truck", "Pickup", "Courier"
  totalPaid      Float?
  currency       String       @default("USD")
  supplier       String?
  notes          String?
  isPaid         Boolean      @default(false)
  paidAt         DateTime?
  orderDate      DateTime     @default(now())
  deliveredAt    DateTime?
  receivedAt     DateTime?
  items          OrderItem[]
  photos         OrderPhoto[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model OrderItem {
  id           String      @id @default(cuid())
  orderId      String
  order        Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  ingredientId String?
  ingredient   Ingredient? @relation(fields: [ingredientId], references: [id], onDelete: SetNull)
  name            String      // display name (copied from ingredient or free text)
  quantity        Float?
  unit            String?     // kg, pcs, liters, etc.
  price           Float?
  notes           String?
  expiryDate      DateTime?
  storageLocation String?
}

model OrderPhoto {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  url       String
  type      PhotoType @default(INGREDIENT)
  caption   String?
  createdAt DateTime @default(now())
}

enum OrderStatus {
  ORDERED
  DELIVERED
  RECEIVED
  STOCKED
  CANCELLED
}

enum PhotoType {
  INVOICE
  INGREDIENT
  OTHER
}

// ─── Traceability (Receipts) ───
// Separate from Orders: receiver chef snaps receipts in the morning,
// AI extracts items, chef confirms, stored by date.

model Receipt {
  id            String         @id @default(cuid())
  userId        String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  receivedAt    DateTime       @default(now()) // when the chef received it (date + time, editable)
  supplier      String?
  total         Float?
  currency      String         @default("USD")
  photoUrl      String
  rawText       String?        // raw text returned by vision model
  notes         String?
  status        ReceiptStatus  @default(CONFIRMED)
  items         ReceiptItem[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([userId, receivedAt])
}

model ReceiptItem {
  id         String   @id @default(cuid())
  receiptId  String
  receipt    Receipt  @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  name       String
  quantity   Float?
  unit       String?
  unitPrice  Float?
  total      Float?
  notes      String?
}

enum ReceiptStatus {
  PENDING
  CONFIRMED
}

// ─── Sub-accounts (employee logins under an owner user) ───
// Owner can create up to 5. Sub-account scopes are enforced in middleware:
// an empty allowed*Ids array = access to all of that type.

model SubAccount {
  id                  String   @id @default(cuid())
  ownerId             String
  owner               User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  email               String
  password            String
  name                String
  isActive            Boolean  @default(true)
  allowedMenuIds      String[] @default([])
  allowedRestaurantIds String[] @default([])
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([ownerId, email])
  @@index([email])
}
